# EvidenceBrief — environment variable template
# Copy to .env.local and fill in your values:
#   cp .env.example .env.local

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe (server-side — never expose in client code)
# Dashboard → Developers → API keys → Secret key
STRIPE_SECRET_KEY=

# Stripe (client-side — safe to expose in browser)
# Dashboard → Developers → API keys → Publishable key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Stripe one-time Price ID for $29.95 CAD hearing package
# Dashboard → Products → [your product] → Pricing → one-time Price ID (price_...)
STRIPE_PRICE_ID=

# AI document generation (future use)
OPENAI_API_KEY=
